    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "ethers": "^6.13.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
