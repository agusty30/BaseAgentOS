# ============================================
# BaseAgent OS — Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://baseagent:baseagent@localhost:5432/baseagent

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-me-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-me-in-production

# Encryption
ENCRYPTION_MASTER_KEY=your-32-byte-hex-key-change-me-in-production

# Base Network RPC
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Default Network (base-mainnet or base-sepolia)
DEFAULT_NETWORK=base-sepolia

# Agent Service
AGENT_SERVICE_URL=http://localhost:8000

# API
API_PORT=3001
API_HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# LLM (for AI agents)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Coinbase Developer Platform
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY=your-cdp-api-key-private-key

# WalletConnect
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# CSRF
CSRF_SECRET=your-csrf-secret-change-me-in-production
